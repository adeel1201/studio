
{
  "entities": {
    "Moment": {
      "title": "Moment",
      "description": "A social post shared by a user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the moment."
        },
        "userName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "userPhoto": {
          "type": "string",
          "description": "The profile photo URL of the user."
        },
        "content": {
          "type": "string",
          "description": "The text content of the moment."
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional URL to an image stored in Firebase Storage."
        },
        "videoUrl": {
          "type": "string",
          "description": "Optional URL to a video stored in Firebase Storage."
        },
        "likes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of user UIDs who liked this moment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the moment was created."
        }
      },
      "required": [
        "userId",
        "userName",
        "content",
        "createdAt"
      ]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a moment.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "userPhoto": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "userName",
        "text",
        "createdAt"
      ]
    },
    "Channel": {
      "title": "Channel",
      "description": "A one-to-many broadcast channel.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "photo": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "adminIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastPost": { "type": "object" }
      },
      "required": ["name", "adminIds", "type", "createdAt"]
    },
    "ChannelPost": {
      "title": "ChannelPost",
      "description": "A broadcast message in a channel.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "authorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "authorId", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/moments/{momentId}": {
      "schema": "Moment",
      "description": "Collection of social moments shared by users."
    },
    "/moments/{momentId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific moment."
    },
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Broadcast channels."
    },
    "/channels/{channelId}/posts/{postId}": {
      "schema": "ChannelPost",
      "description": "Posts within a channel."
    }
  }
}
