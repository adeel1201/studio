
{
  "entities": {
    "Moment": {
      "title": "Moment",
      "description": "A social post shared by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a moment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A one-to-many broadcast channel.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "photo": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "adminIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "adminIds", "type", "createdAt"]
    },
    "CreatorChannel": {
      "title": "CreatorChannel",
      "description": "A public content creator profile for Video Channels.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "privacy": { "type": "string", "enum": ["public", "private", "hidden"] },
        "followerCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "totalLikes": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "name", "username", "privacy"]
    },
    "CreatorPost": {
      "title": "CreatorPost",
      "description": "A social content post in Video Channels.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "image", "text"] },
        "mediaUrl": { "type": "string" },
        "caption": { "type": "string" },
        "privacy": { "type": "string" },
        "likeCount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "type", "timestamp"]
    },
    "UserFollow": {
      "title": "UserFollow",
      "description": "A following relationship between users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile with discovery settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "profilePhoto": { "type": "string" },
        "followingCount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user directory."
    },
    "/moments/{momentId}": {
      "schema": "Moment",
      "description": "Social moments."
    },
    "/creatorChannels/{channelId}": {
      "schema": "CreatorChannel",
      "description": "Video creator profiles."
    },
    "/creatorPosts/{postId}": {
      "schema": "CreatorPost",
      "description": "Video channel posts."
    },
    "/user_follows/{followId}": {
      "schema": "UserFollow",
      "description": "Follow relationships."
    }
  }
}
