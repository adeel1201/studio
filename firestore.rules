
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin(channelId) {
      return isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/channels/$(channelId)).data.adminIds);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == userId;
      
      match /contacts/{contactId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participantIds);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participantIds);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
      }
    }

    // Moments collection
    match /moments/{momentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // Channels collection
    match /channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.adminIds || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerIds']));
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.adminIds);

      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin(channelId);
        allow delete: if isAdmin(channelId);
      }
    }

    // Statuses
    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Calls
    match /calls/{callId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participantIds);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participantIds);
    }

    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
