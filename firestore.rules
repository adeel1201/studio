
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
      match /securityLogs/{logId} {
        allow read, create: if isOwner(userId);
      }
    }

    // Follows
    match /user_follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }

    // Video Channels
    match /creatorChannels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); 
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // Video Posts - Privacy Gates
    match /creatorPosts/{postId} {
      allow read: if isAuthenticated() && (
        resource.data.privacy == 'public' || 
        resource.data.creatorId == request.auth.uid ||
        exists(/databases/$(database)/documents/user_follows/$(request.auth.uid + '_' + resource.data.creatorId))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // Standard Collections
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated();
      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /moments/{momentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/moments/$(momentId)).data.userId == request.auth.uid);
      }
    }

    match /statuses/{statusId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /calls/{callId} {
      allow read, write: if isAuthenticated();
    }
  }
}
